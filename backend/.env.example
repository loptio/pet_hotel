# Copy to .env for local dev. Matches docker-compose postgres service
# (host port 5433 → container 5432).
DATABASE_URL=postgresql+psycopg://pethotel:pethotel@localhost:5433/pethotel
ENVIRONMENT=development

# S1 stub only — real auth/secret handling is S2.
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# Env-ready but NOT wired in S1 (S4 connects these):
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
